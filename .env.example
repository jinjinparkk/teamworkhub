# TeamWorkHub — 환경변수 템플릿
# 로컬 개발: 이 파일을 .env 로 복사 후 값 입력.
# 주의: .env 파일에 실제 키·토큰을 넣지 마세요 — git commit 금지.
#
# 프로덕션: GOOGLE_OAUTH_CLIENT_SECRET / GOOGLE_OAUTH_REFRESH_TOKEN / GEMINI_API_KEY
#   → GCP Secret Manager에 저장 (README § Secret Manager 참조).

# ── Gmail ───────────────────────────────────────────────────────────── #
# 동기화할 라벨 ID. "INBOX" 또는 Gmail 설정에서 확인한 라벨 ID.
GMAIL_LABEL_ID=INBOX

# 멀티 계정 모드 (선택): JSON 배열. 단일 계정이면 비워두세요.
# GMAIL_ACCOUNTS_JSON=[{"email":"you@company.com","refresh_token":"1//..."}]
GMAIL_ACCOUNTS_JSON=

# ── Drive ───────────────────────────────────────────────────────────── #
# /sync 출력 Drive 폴더 ID. Drive 폴더 URL 마지막 세그먼트.
DRIVE_OUTPUT_FOLDER_ID=

# 엔드포인트별 별도 폴더 (선택): 비우면 DRIVE_OUTPUT_FOLDER_ID로 fallback.
DAILY_OUTPUT_FOLDER_ID=
WEEKLY_OUTPUT_FOLDER_ID=
MONTHLY_OUTPUT_FOLDER_ID=

# ── OAuth 2.0 사용자 자격증명 ──────────────────────────────────────── #
# 발급 방법 (최초 1회):
#   1. Cloud Console → APIs & Services → Credentials
#      → OAuth 2.0 Client ID → Desktop app → JSON 다운로드
#      → scripts/client_secret.json 으로 저장
#   2. py -3 scripts/get_token.py  (브라우저 인증 → 아래 3개 값 출력)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# ── Gemini 2.5 Flash (선택) ─────────────────────────────────────────── #
# Google AI Studio (aistudio.google.com) 에서 무료 발급.
# 비워두면 요약·분석 없이 동작합니다.
GEMINI_API_KEY=

# ── 로컬 Obsidian 출력 (선택) ───────────────────────────────────────── #
# 절대 경로. 비워두면 로컬 저장 비활성화.
# Windows 예: C:\Users\name\Documents\ObsidianVault\TeamWorkHub
LOCAL_OUTPUT_DIR=
LOCAL_DAILY_OUTPUT_DIR=
LOCAL_WEEKLY_OUTPUT_DIR=
LOCAL_MONTHLY_OUTPUT_DIR=
LOCAL_DASHBOARD_DIR=

# ── 기타 ────────────────────────────────────────────────────────────── #
MAX_MESSAGES_PER_RUN=50
TIMEZONE=Asia/Seoul           # 다이제스트 시간 기준 (예: Asia/Seoul, UTC)

# ── 서버 / 로깅 ─────────────────────────────────────────────────────── #
PORT=8080                     # Cloud Run이 자동 주입
LOG_FORMAT=pretty             # "json" (프로덕션) | "pretty" (로컬 개발)
LOG_LEVEL=INFO
